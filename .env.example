# ============================================================
# AI Coding 开发流水线 - 环境变量配置
# 使用方式: cp .env.example .env  然后填写实际值
# ============================================================

# === 飞书配置 ===

# 飞书自建应用的 App ID 和 App Secret
# 获取方式: 飞书开放平台 → 应用管理 → 凭证与基础信息
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 飞书事件加密 Key（可选，不配置则不校验签名）
# 获取方式: 飞书开放平台 → 事件订阅 → Encrypt Key
FEISHU_ENCRYPT_KEY=

# 飞书事件验证 Token（可选，用于 Webhook 模式下的请求校验）
# 获取方式: 飞书开放平台 → 事件订阅 → Verification Token
FEISHU_VERIFICATION_TOKEN=

# 飞书群 Webhook 机器人地址（用于群通知，非 Bot 消息）
# 获取方式: 飞书群设置 → 群机器人 → 自定义机器人 → Webhook 地址
FEISHU_BOT_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxx

# --- 飞书多维表格 ---

# 多维表格 App Token
# 获取方式: 打开多维表格 → URL 中 /base/ 后面的字符串
FEISHU_BITABLE_APP_TOKEN=bascnxxxxxxxxxx

# 多维表格 Table ID
# 获取方式: 运行 init_bitable.py 后自动输出，或从 URL 中获取
FEISHU_BITABLE_TABLE_ID=tblxxxxxxxxxx

# --- 飞书审批 ---

# 审批定义 Code（用于代码合并审批流）
# 获取方式: 飞书管理后台 → 审批 → 创建审批 → 审批定义 Code
FEISHU_APPROVAL_CODE=

# --- 飞书云文档 ---

# 技术方案和审查报告存放的文件夹 Token
# 获取方式: 打开目标文件夹 → URL 中 /folder/ 后面的字符串
FEISHU_DOC_FOLDER_TOKEN=

# === AI 模型 API Keys ===

# Anthropic Claude（代码生成主力模型、代码审查模型）
# 获取方式: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# OpenAI GPT-4o（需求分析主力模型）
# 获取方式: https://platform.openai.com/
OPENAI_API_KEY=sk-xxxxxxxxxx

# DeepSeek（轻量快速任务，低成本）
# 获取方式: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxx

# === GitHub ===

# GitHub Personal Access Token（需要 repo 写权限）
# 获取方式: GitHub Settings → Developer settings → Personal access tokens
# 所需权限: repo (Full control of private repositories)
GITHUB_TOKEN=ghp_xxxxxxxxxx

# 目标仓库，格式: owner/repo
GITHUB_REPO=owner/repo

# GitHub Webhook Secret（与仓库 Webhook 配置中的 Secret 一致）
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# === Redis (Celery 任务队列) ===

# Redis 连接地址
# Docker 环境下使用: redis://redis:6379/0
# 本地开发使用: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# === 应用 ===

# 运行环境: development / production
APP_ENV=development

# 服务端口
APP_PORT=8000

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
