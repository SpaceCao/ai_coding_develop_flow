# === 飞书配置 ===
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
FEISHU_BOT_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxx

# 飞书多维表格
FEISHU_BITABLE_APP_TOKEN=bascnxxxxxxxxxx
FEISHU_BITABLE_TABLE_ID=tblxxxxxxxxxx

# 飞书审批
FEISHU_APPROVAL_CODE=

# 飞书云文档（技术方案/审查报告存放文件夹）
